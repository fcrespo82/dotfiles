#!/usr/bin/env zsh

pgrep() {
    command pgrep -fla $@ | grep -E "^[0-9]+"
}

nas() {
    echo "Starting remote ssh port redirect from nas.crespo.com.br:1234 to localhost:22"
    until `ssh -p 3456 fernando@nas.crespo.com.br -R 1234:localhost:22 -N`; do
        echo "Restarting remote ssh port redirect from nas.crespo.com.br:1234 to localhost:22"
        sleep 1
    done
}

psc() {
    cmd='ps axo %cpu,pid,ppid,user,command'
    if [ "$1" == "" ]; then
        echo $cmd
        $cmd;
    else
        echo $cmd
        $cmd | grep "$1" | grep -v "grep $1" | grep -v "bin/psc" | grep -v '$cmd';
    fi;
}

count() {
    if [[ $1 == "" ]]; then
        ls -1 | wc -l | sed "s/ //g"
    else
        while getopts ":a" arg; do
            case "$arg" in
                a) ls -A1 | wc -l | sed "s/ //g";; 
                \?) echo -e "Usage:\n\tcount   \tCount files in a folder (except hidden)\n\tcount -a\tCount files in a folder including hidden";;
            esac
            shift $((OPTIND-1))
        done
    fi
}

to_mp4() {
    FFMPEG=`which ffmpeg`
    file=$1
    $FFMPEG -i "$file" "${file%.*}.mp4"
}

git-status-recursive() {
    find . -name .git -execdir bash -c 'echo -en "\033[1;31m"repo: "\033[1;34m"; basename "`git rev-parse --show-toplevel`"; git status -s' \; 
}


reverse-ssh-connection-nas() {
    echo "Starting remote ssh port redirect from nas:1234 to localhost:22"
    until `ssh -p 3456 root@nas.crespo.com.br -R 1234:localhost:22 -N`; do
        echo "Restarting remote ssh port redirect from nas:1234 to localhost:22"
        sleep 1
    done
}

java-asdf-link() {
    macOS_java_dir=/Library/Java/JavaVirtualMachines
    asdf_java_dir=$ASDF_DIR/installs/java

    if [ -d $asdf_java_dir ]; then
        installs=$(find $asdf_java_dir -type d -depth 1 -print)
        for install in $installs; do
            # echo $install
            # echo find $install -type d -name Home -print 
            founds=$(find $install -type d -name Home -print )
            for found in $founds; do
                destination=$(dirname $(dirname $found))
                source=${destination##*/}
                echo To create links on $macOS_java_dir this script needs Super User powers.
                sudo ln -s "$destination" "$macOS_java_dir/$source"
            done
        done
    fi
}